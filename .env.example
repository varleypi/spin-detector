# ── Anthropic (required for pipeline) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NewsAPI (required for pipeline) ──────────────────────────────────────────
# Free tier: 100 req/day — https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# ── Supabase (required for live mode) ────────────────────────────────────────
# Create a project at supabase.com, then run supabase/schema.sql in the SQL editor.
SUPABASE_URL=https://your-project.supabase.co

# Anon key — safe to expose in frontend (used by Next.js API routes for public reads)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose publicly (used only by the pipeline for writes)
SUPABASE_SERVICE_KEY=eyJ...

# ── App URL (required for server-side API calls in production) ────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Remote pipeline trigger (optional — powers the "Run Pipeline" UI button) ──
# PAT with `workflow` scope (or a fine-grained token with Actions: write).
GITHUB_TOKEN=ghp_...
# Defaults to varleypi/spin-detector if unset.
GITHUB_REPO=varleypi/spin-detector
# Optional shared secret: when set, the /api/pipeline/run endpoint requires an
# x-trigger-secret header. Set both to the same value so the UI can send it.
PIPELINE_TRIGGER_SECRET=your-secret-here
NEXT_PUBLIC_PIPELINE_TRIGGER_SECRET=your-secret-here
