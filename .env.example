# Anthropic API (required for pipeline)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (optional — without these, the app runs in Demo mode with mock data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Base URL for server-side API calls (set to your Vercel URL in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
